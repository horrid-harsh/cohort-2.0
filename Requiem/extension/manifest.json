{
  "manifest_version": 3,
  "name": "Requiem",
  "version": "1.0.0",
  "description": "Save anything from the web to your Requiem knowledge base",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Save to Requiem"
  },
  "permissions": [
    "activeTab",
    "storage",
    "cookies"
  ],
  "host_permissions": [
    "http://localhost:8000/*",
    "http://localhost:5173/*",
    "https://yourdomain.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  }
}
